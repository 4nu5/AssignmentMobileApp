<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pink">


  <LinearLayout
      android:id="@+id/statsLayout"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:gravity="center"
      android:layout_marginTop="40dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

    <TextView android:id="@+id/hungerTextView"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Hunger: 50" android:textSize="28sp" android:textStyle="bold" android:textColor="#000000"/>
    <TextView android:id="@+id/happinessTextView"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Happiness: 50" android:textSize="28sp" android:textStyle="bold" android:textColor="#000000"/>
    <TextView android:id="@+id/cleanlinessTextView"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Cleanliness: 50" android:textSize="28sp" android:textStyle="bold" android:textColor="#000000"/>
  </LinearLayout>


  <TextView
      android:id="@+id/statusPromptText"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Lyon Is OK"
      android:textSize="30sp"
      android:textStyle="bold"
      android:textColor="#555555"
      android:layout_marginTop="15dp"
      app:layout_constraintTop_toBottomOf="@id/petImageView"
      app:layout_constraintBottom_toTopOf="@id/buttonsLayout"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <ImageView
      android:id="@+id/petImageView"
      android:layout_width="300dp"
      android:layout_height="300dp"
      android:src="@drawable/lyon_happy"
      app:layout_constraintTop_toBottomOf="@id/statsLayout"
      app:layout_constraintBottom_toTopOf="@id/buttonsLayout"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <ImageView
      android:id="@+id/gameOverImage"
      android:layout_width="380dp"   android:layout_height="250dp"  android:alpha="0.75"
      android:src="@drawable/wasted"
      android:visibility="gone"
      app:layout_constraintTop_toTopOf="@id/petImageView"
      app:layout_constraintBottom_toBottomOf="@id/petImageView"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

  <ImageView
      android:id="@+id/dirtOverlay"
      android:layout_width="300dp"
      android:layout_height="300dp"
      android:src="@drawable/dirt"
      android:alpha="0.0"
      app:layout_constraintTop_toTopOf="@id/petImageView"
      app:layout_constraintBottom_toBottomOf="@id/petImageView"
      app:layout_constraintStart_toStartOf="@id/petImageView"
      app:layout_constraintEnd_toEndOf="@id/petImageView" />

  <LinearLayout
      android:id="@+id/buttonsLayout"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center"
      android:layout_marginBottom="50dp"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent">

    <Button android:id="@+id/feedButton"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Feed" android:layout_marginEnd="10dp"/>
    <Button android:id="@+id/cleanButton"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clean" />
  </LinearLayout>

  <Button
      android:id="@+id/restartButton"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Restart Game"
      android:visibility="gone"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      android:layout_marginBottom="50dp" />

</androidx.constraintlayout.widget.ConstraintLayout>